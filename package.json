{
  "name": "onhands3",
  "version": "0.6.1",
  "description": "AI-driven smart cursor — voice/text commands via mouse long-press, executed by AI agents",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "preview": "node scripts/dev.js preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "koffi": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "selection-hook": "^2.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^37.10.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.onhands3.app",
    "productName": "OnHands3",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/tray.ico",
        "to": "tray.ico"
      },
      {
        "from": "scripts/selection-worker.cjs",
        "to": "scripts/selection-worker.cjs"
      },
      {
        "from": "node_modules/selection-hook",
        "to": "node_modules/selection-hook",
        "filter": ["**/*", "!examples/**", "!docs/**", "!build/**", "!.clang-format-ignore"]
      },
      {
        "from": "node_modules/node-gyp-build",
        "to": "node_modules/node-gyp-build"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OnHands3"
    }
  }
}
