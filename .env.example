# AI Service (for simple tasks — translate, calculate, chat)
AI_API_KEY=
AI_BASE_URL=https://apihub.agnes-ai.com/v1
AI_MODEL=agnes-2.0-flash
AI_MAX_TOKENS=1024

# Agent CLI paths (auto-detected if on PATH)
CLAUDE_CODE_PATH=
CODEX_PATH=
OPENCODE_PATH=

# STT configuration
STT_MODE=local
WHISPER_MODEL=base

# Input sensitivity
LONG_PRESS_DURATION=800
DRAG_THRESHOLD_PX=15

# Data directory (defaults to <userData>/data)
DATA_DIR=
